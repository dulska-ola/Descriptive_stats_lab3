    "     \"text\": [\n",
    "      \"result for 9 is 2482.7931\\n\"\n",
    "     ]\n",
    "    }\n",
    "   ],\n",
    "   \"execution_count\": 13\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 4 Moving average\\n\",\n",
    "    \"Let’s assume, we have a full data set, for example opening stock prices from the whole last year (one price a day). Commonly, we are interested in creating series of averages of different subsets of that full data set, for example the averages of the stock prices from the last 10 days, computed everyday. moving means that it is applied to subsequent data points.\\n\",\n",
    "    \"\\n\",\n",
    "    \"Task:\\n\",\n",
    "    \"\\n\",\n",
    "    \"6) Load *data_1000_days.txt* file and compute exponential moving average using *exp_avr()* function for *n=10* starting with 11-th day ($EMA_{10}$)\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"metadata\": {\n",
    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2026-04-17T12:28:15.514389500Z\",\n",
    "     \"start_time\": \"2026-04-17T12:28:15.395292Z\"\n",
    "    }\n",
    "   },\n",
    "   \"source\": [\n",
    "    \"file_path = 'data_1000_days.txt'\\n\",\n",
    "    \"data_1000_days = np.loadtxt(file_path, delimiter=',', dtype=float)\\n\",\n",
    "    \"\\n\",\n",
    "    \"exp_aver = np.zeros_like(data_1000_days)\\n\",\n",
    "    \"\\n\",\n",
    "    \"for i in range(10, len(data_1000_days)):\\n\",\n",
    "    \"    window = data_1000_days[i-10:i+1]\\n\",\n",
    "    \"    exp_aver[i] = exp_avr(window[::-1], 10) #switching\\n\",\n",
    "    \"print(exp_aver)\\n\"\n",
    "   ],\n",
