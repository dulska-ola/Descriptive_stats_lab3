    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 5. MACD indicator \\n\",\n",
    "    \"\\n\",\n",
    "    \"MACD and SIGNAL are defined as follows:\\n\",\n",
    "    \"1. MACD = EMA12 − EMA26, where EMA12 and EMA26 are computed based on the stock prices data.\\n\",\n",
    "    \"2. SIGNAL = EMA9 is computed based on MACD plot.\\n\",\n",
    "    \"\\n\",\n",
    "    \"Tasks:\\n\",\n",
    "    \"\\n\",\n",
    "    \"7) Generate MACD and SIGNAL for *data_1000_days.txt*\\n\",\n",
    "    \"8) Plot MACD and SIGNAL. Observe the correlation between data_1000_days plot and cross sections of MACD and SIGNAL. Use plt.xlim() and plt.ylim().   \\n\",\n",
    "    \"9) Write short comments - can you predict the future prices using MACD indicator? \\n\",\n",
    "    \"10) Save the notebook and upload on enauczanie course site. \"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"metadata\": {\n",
    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2026-04-17T12:23:56.141458100Z\",\n",
    "     \"start_time\": \"2026-04-17T12:23:55.801966Z\"\n",
    "    }\n",
    "   },\n",
    "   \"source\": [\n",
    "    \"import numpy as np\\n\",\n",
    "    \"import matplotlib.pyplot as plt\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"## 5. MACD indicator\\n\",\n",
    "    \"exp_aver12 = np.zeros_like(data_1000_days)\\n\",\n",
    "    \"exp_aver26 = np.zeros_like(data_1000_days)\\n\",\n",
    "    \"signal = np.zeros_like(data_1000_days)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# EMA12\\n\",\n",
    "    \"for i in range(12, len(data_1000_days)):\\n\",\n",
    "    \"    exp_aver12[i] = exp_avr(data_1000_days[i - 12:i + 1], 12)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# EMA26\\n\",\n",
    "    \"for i in range(26, len(data_1000_days)):\\n\",\n",
    "    \"    exp_aver26[i] = exp_avr(data_1000_days[i - 26:i + 1], 26)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# MACD\\n\",\n",
    "    \"MACD = exp_aver12 - exp_aver26\\n\",\n",
    "    \"\\n\",\n",
    "    \"# SIGNAL line (EMA9 of MACD)\\n\",\n",
    "    \"for i in range(9, len(MACD)):\\n\",\n",
    "    \"    signal[i] = exp_avr(MACD[i - 9:i + 1], 9)\\n\",\n",
    "    \"\\n\",\n",
    "    \"## Plot stock prices\\n\",\n",
    "    \"\\n\",\n",
    "    \"plt.figure()\\n\",\n",
    "    \"plt.plot(data_1000_days, label=\\\"Stock prices\\\")\\n\",\n",
    "    \"plt.title(\\\"Stock Prices\\\")\\n\",\n",
    "    \"plt.grid()\\n\",\n",
    "    \"plt.show()\\n\",\n",
    "    \"\\n\",\n",
    "    \"## Plot MACD and SIGNAL\\n\",\n",
    "    \"\\n\",\n",
    "    \"plt.figure()\\n\",\n",
    "    \"plt.plot(MACD, label=\\\"MACD\\\")\\n\",\n",
    "    \"plt.plot(signal, label=\\\"SIGNAL\\\")\\n\",\n",
    "    \"plt.legend()\\n\",\n",
    "    \"plt.title(\\\"MACD Indicator\\\")\\n\",\n",
    "    \"plt.xlim(300,400)\\n\",\n",
    "    \"plt.ylim(-300,100)\\n\",\n",
    "    \"plt.grid()\\n\",\n",
    "    \"plt.show()\\n\",\n",
    "    \"\\n\",\n",
    "    \"## Task 9 - Comments\\n\",\n",
    "    \"# MACD shows trend momentum:\\n\",\n",
    "    \"# - MACD > SIGNAL -> upward trend (buy signal)\\n\",\n",
    "    \"# - MACD < SIGNAL <- downward trend (sell signal)\\n\",\n",
    "    \"# MACD cannot predict future prices, but helps identify trend changes.\"\n",
